# Copy to .env and fill in (setup.sh does this for you). Never commit .env.

# --- Claude Code LLM (the agent's brain) ---
# Get one at https://console.anthropic.com/ . A Claude Pro/Max subscription works too
# (just run `claude` and log in), in which case you can leave this blank.
ANTHROPIC_API_KEY=

# --- Your personal access to the LIVE fleet agent (real BigQuery / HubSpot / etc.) ---
# This is YOUR per-user key from the admin panel: People & Keys → "New key".
# The `fleet` skill sends it as `Authorization: Bearer <key>` to AGENT_BASE_URL/query.
FLEET_API_KEY=

# Base URL of the deployed agent (the admin "HTTP & API" tab shows the exact value).
# "/query" is appended automatically. One agent (pod) per URL.
AGENT_BASE_URL=

# --- Central Skills Gateway (OPTIONAL: read-only browsing of the shared library) ---
# Ask the fleet admin for the gateway token. Keep the "Bearer " prefix. Leave blank to skip.
SAASLABS_SKILLS_API_KEY=

# Which pod persona this local agent runs as: dwight | jim | toby | ryan | pam
POD=dwight
